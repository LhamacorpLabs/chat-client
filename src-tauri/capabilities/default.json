{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-set-badge-count",
    "updater:default",
    "notification:default",
    "process:allow-restart",
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://*" },
        { "url": "https://**" },
        { "url": "http://*" },
        { "url": "http://**" },
        { "url": "mailto:*" },
        { "url": "tel:*" }
      ]
    },
    "store:default"
  ]
}
