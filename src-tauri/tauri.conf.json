{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Chat",
  "version": "0.1.0",
  "identifier": "com.lhamacorp.chat",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Chat",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/LhamacorpLabs/chat-client/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxNzBCNjM0Qjg4NTAyQUIKUldTckFvVzROTFp3d1F0bHU3eGM2Q0xmeUFLMlpzcTkrNDRFbU1VWWN0WnVwR1U3S2hRclJlUVEK"
    }
  }
}
